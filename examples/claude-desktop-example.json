{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@1.2.0",
        "/home/user/Documents",
        "--read-only"
      ],
      "env": {
        "LOG_LEVEL": "info"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@1.0.0"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "LOG_LEVEL": "info"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search@1.0.0"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "LOG_LEVEL": "info"
      }
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory@1.0.0"
      ],
      "env": {
        "LOG_LEVEL": "info"
      }
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer@1.0.0"
      ],
      "env": {
        "LOG_LEVEL": "warn"
      }
    }
  }
}
